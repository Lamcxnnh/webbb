<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.lease.web.admin.mapper.GraphInfoMapper">

    <select id="selectGraphByItemTypeAndItemId" resultType="com.example.lease.web.admin.vo.graph.GraphVo">
        select gi.name,
               gi.url
        from graph_info gi
        where gi.is_deleted = 0
          and gi.item_type = #{itemType}
          and gi.item_id = #{itemId}
    </select>

</mapper>
